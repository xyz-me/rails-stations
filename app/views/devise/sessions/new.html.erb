<div class="my-10 max-w-xl mx-auto shadow-lg p-4 text-center rounded-xl">
  <h2 class="text-3xl">ログイン</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="field w-full text-left my-4">
      <p><%= f.label :email, class:"text-base"%></p>
      <p><%= f.email_field :email, autofocus: true, autocomplete: "email", class:"w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500" %></p>
    </div>

    <div class="field w-full text-left  my-4">
      <p><%= f.label :password %></p>
      <p><%= f.password_field :password, autocomplete: "current-password", class:"w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500" %></p>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="field w-full text-left flex  my-4 gap-2">
        <p><%= f.check_box :remember_me %></p>
        <p><%= f.label :remember_me %></p>
      </div>
    <% end %>

    <div class="actions w-full">
      <%= f.submit "ログイン", class:"bg-[#d30000] text-white p-2 rounded w-full text-lg cursor-pointer" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>