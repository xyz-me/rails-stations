<!DOCTYPE html>
<html>
  <head>
    <title>App</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <header class="bg-[#d30000] text-[#ffffff] py-4">
    <div class="container mx-auto px-4 flex justify-between">
    <h1><%= link_to "Cinema", "/", class: "text-[#ffffff] text-xl font-bold" %><h1>
    <ul class="flex justify-between gap-2">
      <% if user_signed_in? %>
        <li>
          <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class:"p-2 border rounded-xl" %>
        </li>
      <% else %>
        <li>
          <%= link_to "新規登録", new_user_registration_path, class:"p-2 border rounded-xl" %>
        </li>
        <li>
          <%= link_to "ログイン", new_user_session_path, class:"p-2 border rounded-xl" %>
        </li>
      <% end %>
    </ul>
    </div>
  </header>

  <body>
    <main class="container mx-auto px-4">
      <%= yield %>
    </main>
  </body>
</html>
