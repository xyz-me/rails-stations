<h1><%= @movie.name %></h1>


<%= form_with model: [:admin, @movie, @schedule] , method: :put do |form| %>
    <% if form.object.errors.any? %>
        <p class="error"><%= form.object.errors.full_messages.first %></p>
    <% end %>


    <div>
        <%= form.label :movie_id %>
        <%= form.text_field  :movie_id ,readonly: true %>
    </div>

    <div>
        <%= form.label :start_time %>
        <%= form.datetime_field :start_time %>
    </div>

    <div>
        <%= form.label :end_time %>
        <%= form.datetime_field :end_time %>
    </div>

    <div>
        <%= form.submit %>
    </div>
<% end %>
<%= button_to "削除", [:admin, @movie, @schedule], { method: :delete, form: { data: { turbo_confirm: "本当に削除しますか？" } } } %>
