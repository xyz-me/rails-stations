<h1>スケジュールを追加</h1>
<%= form_with model: [:admin, @movie, @schedule] , method: :post do |form| %>
    <% if form.object.errors.any? %>
        
        <p class="error"><%= form.object.errors.full_messages.first %></p>
    <% end %>

    <div>
        <%= form.label :movie_id %>
        <%= form.text_field  :movie_id , value: @movie.id, readonly: true %>
    </div>

    <div>
        <%= form.label :start_time %>
        <%= form.datetime_field :start_time %>
    </div>

  <div>
    <%= form.label :end_time %>
    <%= form.datetime_field :end_time %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
